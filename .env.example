# === Instagram (Direct Login) ===
# Your Instagram username and password — that's it!
INSTAGRAM_USERNAME=xaviaestate
INSTAGRAM_PASSWORD=your_password_here

# === TikTok API ===
# 1. Go to https://developers.tiktok.com → Create App
# 2. Add "Content Posting API" scope
# 3. Complete OAuth flow to get access token
TIKTOK_ACCESS_TOKEN=your_tiktok_token_here

# === Claude AI (for AI-generated property descriptions) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Agent Settings ===
# Cron schedule for checking new properties (default: every day at 9am)
CRON_SCHEDULE=0 9 * * *
# Set to "true" to run without actually posting
DRY_RUN=true
# Base URL for scraping
XAVIA_BASE_URL=https://www.xaviaestate.com
